{
  "name": "beslutteroversikt",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "homepage": "/beslutteroversikt",
  "scripts": {
    "start": "vite --mode lokal",
    "build:mock": "tsc && vite build --mode lokal --base=/beslutteroversikt/",
    "build:dev": "tsc && vite build --mode development",
    "build:prod": "tsc && vite build --mode production",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "pre-commit": "lint-staged --verbose echo \"Linting files...\"",
    "test": "echo \"Tests not yet implemented\""
  },
  "lint-staged": {
    "src/**/*.{json,less,css,md}": [
      "prettier --write"
    ],
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --config eslint.config.lintstaged.js"
    ]
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@navikt/aksel-icons": "8.11.1",
    "@navikt/ds-css": "8.11.1",
    "@navikt/ds-react": "8.11.1",
    "@navikt/fnrvalidator": "2.2.1",
    "classnames": "2.5.1",
    "constate": "4.0.0",
    "dayjs": "1.11.21",
    "lodash.debounce": "4.0.8",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@faker-js/faker": "10.4.0",
    "@types/lodash.debounce": "4.0.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "less": "4.6.4",
    "lint-staged": "17.0.7",
    "msw": "2.14.6",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
